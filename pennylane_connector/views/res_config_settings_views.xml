<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_pennylane" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.pennylane</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='account.fiscal_localization_setting']" position="before">
                <block title="Pennylane" name="pennylane_settings">
                    <setting string="Connexion API Pennylane"
                             help="Configurez votre token pour importer les factures depuis Pennylane">
                        <div class="content-group">
                            <div class="row mt16">
                                <label for="pennylane_api_token" class="col-3 o_light_label"/>
                                <field name="pennylane_api_token" class="col-9"
                                       password="True"/>
                            </div>
                            <div class="row mt8">
                                <label for="pennylane_api_base_url" class="col-3 o_light_label"/>
                                <field name="pennylane_api_base_url" class="col-9"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>
