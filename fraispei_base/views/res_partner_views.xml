<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extension du formulaire partenaire - Onglet FRAIS PEI -->
    <record id="view_partner_form_fraispei" model="ir.ui.view">
        <field name="name">res.partner.form.fraispei</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page string="FRAIS PEI" name="fraispei_tab">

                    <!-- Section client -->
                    <group string="Informations Client" invisible="customer_rank == 0">
                        <group>
                            <field name="x_groupe_client"/>
                            <field name="x_enseigne"/>
                            <field name="x_groupe_facturation"/>
                        </group>
                        <group>
                            <field name="x_taux_remise"/>
                            <field name="x_taux_rfa"/>
                            <field name="x_blocage"/>
                        </group>
                    </group>

                    <!-- Section fournisseur -->
                    <group string="Informations Fournisseur" invisible="supplier_rank == 0">
                        <group>
                            <field name="x_nom_commercial"/>
                            <field name="x_groupe_fournisseur"/>
                            <field name="x_code_interne"/>
                        </group>
                        <group>
                            <field name="x_is_transitaire"/>
                            <field name="x_delai_livraison"/>
                            <field name="x_numero_client_chez_frs"/>
                        </group>
                        <group>
                            <field name="x_incoterm"/>
                            <field name="x_conditions_achat"/>
                        </group>
                    </group>

                    <!-- Comptabilité -->
                    <group string="Comptabilité FRAIS PEI">
                        <group>
                            <field name="x_compte_comptable"/>
                            <field name="x_compte_auxiliaire"/>
                        </group>
                        <group>
                            <field name="x_resp_compta"/>
                            <field name="x_tel_compta"/>
                            <field name="x_email_compta"/>
                        </group>
                    </group>

                    <!-- Responsables -->
                    <group string="Responsables">
                        <group>
                            <field name="x_responsable_1"/>
                            <field name="x_responsable_2"/>
                        </group>
                    </group>

                </page>
            </xpath>
        </field>
    </record>

</odoo>
