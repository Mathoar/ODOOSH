<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extension du formulaire produit - Onglet FRAIS PEI -->
    <record id="view_product_template_form_fraispei" model="ir.ui.view">
        <field name="name">product.template.form.fraispei</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='inventory']" position="after">
                <page string="FRAIS PEI" name="fraispei_product_tab">

                    <group string="Identification">
                        <group>
                            <field name="x_code_interne"/>
                            <field name="x_nom_long"/>
                            <field name="x_marque"/>
                            <field name="x_origine"/>
                        </group>
                        <group>
                            <field name="x_segment"/>
                            <field name="x_zone_peche"/>
                            <field name="x_nom_scientifique"/>
                        </group>
                    </group>

                    <group string="Conditionnement">
                        <group>
                            <field name="x_contenu"/>
                            <field name="x_conditionnement"/>
                            <field name="x_pcb"/>
                        </group>
                        <group>
                            <field name="x_poids_brut"/>
                            <field name="x_coef_approche"/>
                            <field name="x_taux_om"/>
                        </group>
                    </group>

                    <group string="Prix et Tarifs">
                        <group>
                            <field name="x_pv_ttc"/>
                            <field name="x_pr_ttc"/>
                            <field name="x_prmup"/>
                        </group>
                    </group>

                    <group string="Grille Tarifaire">
                        <group>
                            <field name="x_tarif_t1_ht"/>
                            <field name="x_tarif_t2_ht"/>
                            <field name="x_tarif_t3_ht"/>
                        </group>
                        <group>
                            <field name="x_tarif_t4_ht"/>
                            <field name="x_tarif_t5_ht"/>
                            <field name="x_tarif_t6_ht"/>
                        </group>
                    </group>

                </page>
            </xpath>
        </field>
    </record>

</odoo>
